APP_NAME="Emisora Online"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-app.railway.app

APP_LOCALE=es
APP_FALLBACK_LOCALE=es

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_URL=
# Railway PostgreSQL inyecta DATABASE_URL automáticamente (DB_URL la usa el start script)

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
